{
  "name": "schnucks-coupons",
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "description": "Automated coupon clipper for Schnucks",
  "main": "dist/index.cjs",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.cjs",
    "start": "node dist/index.cjs",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/unit/config.test.ts tests/unit/logger.test.ts tests/unit/session.test.ts tests/unit/api.test.ts tests/unit/clipper.test.ts tests/unit/run-summary-store.test.ts tests/unit/run-summary-store-appconfig.test.ts tests/unit/weekly-summary-config.test.ts tests/unit/weekly-summary.test.ts tests/integration/clipper.integration.test.ts",
    "test:weekly-summary": "tsx scripts/test-weekly-summary-local.ts",
    "session:init": "tsx src/session-init.ts",
    "validate": "pnpm format && pnpm lint:fix && pnpm typecheck && pnpm test && pnpm build && pnpm bundle"
  },
  "keywords": [
    "schnucks",
    "coupons",
    "playwright",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/app-configuration": "^1.11.0",
    "@azure/identity": "^4.13.0",
    "dotenv": "^17.3.1",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@types/nodemailer": "^7.0.11",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "playwright-chromium": "^1.58.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
